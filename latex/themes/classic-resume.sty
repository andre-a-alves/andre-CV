\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{themes/classic-resume}[2026-04-10 Classic resume theme]

\RequirePackage[\cv@papersize, margin=0.75in]{geometry}
\RequirePackage[en-US, useregional]{datetime2}

\newcommand{\InsertHeader}{}

\setlength{\parindent}{0pt}
\DTMsetstyle{en-US}

\pagestyle{fancy}
\chead{\InsertHeader}
\rhead{}
\lfoot{\FooterGrayColor{\today}}
\geometry{includehead, headsep=0.2in, footskip=0.25in}
\fancypagestyle{noheader}{\fancyhead{}}

\renewcommand*{\cv@render@header}{%
	\def\InsertHeader{%
		\HUGE \textsc{\DisplayName}\\
		\small \cv@header@subtitle \\
		\cv@header@contact%
	}%
}

\renewcommand*{\cv@render@entry}[1]{%
	\begin{minipage}{\textwidth}
	\vspace{4mm}%
	\setlength\tabcolsep{0pt}%
	\setlength{\extrarowheight}{0pt}%
	\begin{tabularx}{\textwidth}{X r}
		\large{\textbf{\cv@entry@linktitle}} & \color{accentColor}\cv@entry@dates \\
		\textsc{\cv@entry@org} & {\small \cv@entry@location}
	\end{tabularx}
	#1
	\end{minipage}%
}

\renewcommand*{\cv@render@item}[2]{%
	\vspace{1.5mm}%
	\setlength\tabcolsep{0pt}%
	\setlength{\extrarowheight}{0pt}%
	\begin{tabularx}{\textwidth}{l l X}%
		\textbf{#1} & \hspace{0.3cm} & #2 \\
	\end{tabularx}%
}
