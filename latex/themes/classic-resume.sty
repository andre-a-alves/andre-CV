\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{themes/classic-resume}[2026-04-13 Classic resume theme]
% Layout inspired by Jan Kuester's latexcv Classic template.

\RequirePackage[\cv@papersize, top=1.25cm, bottom=1.25cm, left=1.5cm, right=1.5cm]{geometry}
\RequirePackage[en-US, useregional]{datetime2}

\definecolor{ClassicBgColor}{RGB}{110,110,110}
\definecolor{ClassicSoftColor}{RGB}{212,212,212}

\setlength{\parindent}{0pt}
\DTMsetstyle{en-US}

\pagestyle{fancy}
\fancyhf{}
\fancypagestyle{letter}{\fancyhf{}}
\fancypagestyle{noheader}{\fancyhead{}}
\renewcommand{\headrulewidth}{0pt}
\renewcommand{\footrulewidth}{0pt}
\geometry{footskip=0.25in}

\newcommand*{\DisplayClassicHeader}[2]{%
  \thispagestyle{noheader}%
  \vspace*{-8pt}%
  \begin{center}
    {\HUGE \textsc{\DisplayName} \textcolor{accentColor}{\rule[-1mm]{1mm}{0.9cm}} \textsc{#1}}\\[2pt]
    {\small #2}%
  \end{center}%
  \vspace{6pt}%
}

\newcommand*{\ClassicMeta}[2]{%
  {\footnotesize #2\hspace*{\fill}\footnotesize #1}\\[0pt]%
}

\newcommand*{\ClassicMetaRule}{%
  \vspace{-2pt}%
  \textcolor{ClassicSoftColor}{\hrule}%
  \vspace{6pt}%
}

\renewcommand*{\cv@render@sectionheading}[1]{%
  \begin{center}
    {\large\textcolor{accentColor}{\textbf{#1}}}%
  \end{center}%
}

\newcommand*{\classic@entry@details}{%
  \ifthenelse{\equal{\cv@entry@org}{}}{}{ -- \textcolor{ClassicBgColor}{\cv@entry@org}}%
  \ifthenelse{\equal{\cv@entry@location}{}}{}{ \textcolor{ClassicBgColor}{(\cv@entry@location)}}%
}

\renewcommand*{\cv@render@entry}[1]{%
  \vspace{4mm}%
  \begin{minipage}{\textwidth}
  \setlength\tabcolsep{0pt}%
  \setlength{\extrarowheight}{0pt}%
  \begin{tabularx}{\textwidth}{X r}
    \textbf{\cv@entry@linktitle}\classic@entry@details & \textcolor{accentColor}{\cv@entry@dates}
  \end{tabularx}
  \vspace{-2pt}%
  \textcolor{ClassicSoftColor}{\hrule}%
  \vspace{10pt}%
  #1
  \vspace{3pt}%
  \end{minipage}%
}

\renewcommand*{\cv@render@item}[2]{%
  \vspace{1.5mm}%
  \setlength\tabcolsep{0pt}%
  \setlength{\extrarowheight}{0pt}%
  \begin{tabularx}{\textwidth}{@{} l @{\hspace{0.6em}} X @{}}%
    \textbf{#1} & #2 \\
  \end{tabularx}%
}

% TODO: Design a themed cover letter layout matching the classic-resume
% aesthetic — name/contact header styled like \DisplayClassicHeader,
% with the accent rule and \ClassicMeta contact block.
\renewcommand{\cv@renderletter@begin}{%
  \thispagestyle{letter}%
  \newgeometry{margin=0.75in}%
  {\Large\bfseries \DisplayName}\\
  \@ifundefined{DisplayAddressOne}{}{\DisplayAddressOne\\}%
  \@ifundefined{DisplayAddressTwo}{}{\DisplayAddressTwo\\}%
  \@ifundefined{DisplayAddressThree}{}{\DisplayAddressThree\\}%
  \@ifundefined{DisplayPhone}{}{\DisplayPhone\\}%
  \@ifundefined{DisplayEmail}{}{\DisplayEmail\\}%
  \today\\[1\baselineskip]
  \textsc{\cv@letter@toname}\\
  \cv@letter@toaddress\\[1\baselineskip]
  \textbf{\cv@letter@subject}\\[0.5\baselineskip]
  \cv@letter@opening\\
}

\renewcommand{\cv@renderletter@end}{%
  \par
  \cv@letter@closing,\\
  \ifthenelse{\equal{\cv@letter@signature}{}}%
    {\\[3\baselineskip]}%
    {\includegraphics[height=3\baselineskip]{\cv@letter@signature}\\}%
  \DisplayName
  \restoregeometry
  \setcounter{page}{1}%
}

\newcommand{\MakeCoverLetter}[9]{%
  \PackageWarning{themes/classic-resume}{\noexpand\MakeCoverLetter is deprecated; use the coverletter environment instead}%
  \begin{coverletter}[%
    to-name    = {#3},%
    to-address = {#4},%
    subject    = {#5},%
    opening    = {#6},%
    closing    = {#8},%
    signature  = {#9}%
  ]%
  #7%
  \end{coverletter}%
}

% TODO: Add a \cvpublication (or biblatex driver) command that renders a
% publication entry in the classic-resume style — bold title, gray venue,
% authors on the left and accent-colored year on the right, consistent
% with \cv@render@entry.

\newcommand*{\cventrylegacy}[5]{%
  \def\cv@entry@dates{#1}%
  \def\cv@entry@title{#2}%
  \def\cv@entry@org{#3}%
  \def\cv@entry@location{#4}%
  \def\cv@entry@url{}%
  \cv@render@entry{#5}%
}

\newcommand*{\cvlistitem}[3]{%
  \vspace{1.5mm}%
  \setlength\tabcolsep{0pt}%
  \setlength{\extrarowheight}{0pt}%
  \begin{tabularx}{\textwidth}{l X}%
    \ifthenelse{\equal{#3}{}}%
      {\textbf{#1}}%
      {\href{#3}{\textbf{#1}}}%
      & #2 \\
  \end{tabularx}\\%
}
