\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{themes/modern}[2026-04-14 Modern resume theme]
% Layout derived from themes/us-resume.sty. Modernizes visual style only:
% no small caps, quieter accent, gray secondary metadata, tighter typography.

\RequirePackage[\cv@papersize, margin=0.75in]{geometry}
\RequirePackage[en-US, useregional]{datetime2}
\RequirePackage{ragged2e}

\newbool{BadgeToggled}
\newcommand{\InsertHeader}{}

\setlength{\parindent}{0pt}
\DTMsetstyle{en-US}

% Disable hyphenation so words never break across lines.
\hyphenpenalty=10000
\exhyphenpenalty=10000
\emergencystretch=2em

\pagestyle{fancy}
\chead{\InsertHeader}
\rhead{\ifbool{BadgeToggled}{\InsertBadge}{}}
\lfoot{\FooterGrayColor{\today}}
\geometry{includehead, headsep=0.1in, footskip=0.25in}
\fancypagestyle{noheader}{\fancyhead{}}

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
%
% Colors
%
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

% Muted slate blue — professional and restrained vs the default bright blue.
\definecolor{ModernAccent}{HTML}{4A6FA5}
\colorlet{accentColor}{ModernAccent}

% Medium gray for all secondary metadata (dates, org, location).
\definecolor{ModernGray}{HTML}{666666}

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
%
% Header
%
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

\begin{luacode}
  function printModernHeaderPersonalDetails(arr)
    local items = {}
    for _, detail in ipairs(arr) do
      items[#items + 1] = detail
    end
    table.sort(items, function(a, b)
      return (a.sortKey or 0) < (b.sortKey or 0)
    end)

    local texItems = {}
    for _, detail in ipairs(items) do
      if (detail.sortKey or 0) >= 50 then
        texItems[#texItems + 1] = "\\mbox{" .. detail.icon .. detail.value .. "}"
      else
        texItems[#texItems + 1] = "\\mbox{" .. detail.value .. "}"
      end
    end

    tex.sprint(table.concat(texItems, "\\hspace{0.45em}{\\textperiodcentered}\\hspace{0.45em}"))
  end
\end{luacode}

\newcommand*{\RenderPersonalDetails}{%
  \directlua{printModernHeaderPersonalDetails(personalDetails)}%
}

% \MakeHeader{name}{subtitle}
%
%   #1  name        — bold, most prominent
%   #2  subtitle    — professional identity; gray, slightly smaller than name
%
% Tighten inter-line gaps to zero: the size difference alone carries the
% hierarchy without needing extra vertical distance between the lines.
\newcommand*{\MakeHeader}[2]{%
  \def\InsertHeader{%
    {\LARGE\bfseries #1}\\[0pt]%
    {\small\color{ModernGray} #2}\\[0pt]%
    {\fontsize{8.5}{10}\selectfont\color{ModernGray}\RenderPersonalDetails}%
  }%
}

\newcommand*{\SetBadge}[2]{%
  \booltrue{BadgeToggled}%
  \def\InsertBadge{\includegraphics[scale=#1]{#2}}%
}

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
%
% Section headings
%
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

\newlength{\cv@modern@sectionpostskip}
\setlength{\cv@modern@sectionpostskip}{3mm}
\newbool{cv@modern@aftersection}

% \large (12 pt at 10 pt base) instead of \Large (14.4 pt): readable but
% quieter. Accent color + rule provides the visual landmark; the label
% does not need to shout.
\renewcommand*{\cv@render@sectionheading}[1]{%
  \par%
  \RaggedRight%
  \vspace{6mm}%
  \noindent{\large\bfseries\color{accentColor}#1}%
  ~{\color{light_gray}\leavevmode\leaders\hrule height 0.2pt\hfill\kern0pt}\par%
  \nobreak\vspace{\cv@modern@sectionpostskip}%
  \booltrue{cv@modern@aftersection}%
}

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
%
% CV entry
%
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

% Title: bold at body size — weight alone distinguishes it from bullets.
% Dates, org, location: \small gray — secondary info reads quietly without
% accent color or small caps.
\newcommand*{\cv@modern@entrytopspace}{%
  \ifbool{cv@modern@aftersection}{%
    \boolfalse{cv@modern@aftersection}%
  }{%
    \vspace{3mm}%
  }%
}

\renewcommand*{\cv@render@entry}[1]{%
  \cv@modern@entrytopspace%
  \noindent\begin{minipage}{\textwidth}
  % Use \hfill in paragraph mode so every row shares a natural baseline —
  % no tabular vtop gymnastics needed.
  {\parfillskip=0pt\relax
   \noindent\textbf{\cv@entry@linktitle}\hfill{\footnotesize\color{ModernGray}\cv@entry@dates}\\[-2pt]
   {\footnotesize\color{ModernGray}\cv@entry@org}\hfill{\footnotesize\color{ModernGray}\cv@entry@location}\par}%
  \vspace{2mm}%
  {\fontsize{9.5}{11.5}\selectfont #1}%
  \end{minipage}\par%
}

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
%
% CV item
%
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

\newlength{\cv@item@labelwidth}
\setlength{\cv@item@labelwidth}{3cm}

\newcommand*{\cv@render@itemrow}[2]{%
  \par\vspace{0.3mm}%
  {\fontsize{9.5}{11.5}\selectfont
   \hangindent=\dimexpr\cv@item@labelwidth+0.3cm\relax
   \hangafter=1
   \noindent\makebox[\cv@item@labelwidth][l]{\strut#1}\hspace{0.3cm}#2\strut\par}%
  \vspace{0.3mm}%
}

\renewcommand*{\cv@render@item}[2]{%
  \cv@render@itemrow{\textbf{#1}}{#2}%
}

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
%
% Bibliography
%
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

\AtBeginDocument{%
  \@ifpackageloaded{biblatex}{%
    \renewcommand*{\bibfont}{\fontsize{9.5}{11.5}\selectfont\RaggedRight}%
    \setlength{\bibitemsep}{0.6\baselineskip}%
    \setlength{\bibparsep}{0pt}%
    \pretocmd{\printbibliography}{%
      \ifbool{cv@modern@aftersection}{%
        \vspace{-\cv@modern@sectionpostskip}%
        \boolfalse{cv@modern@aftersection}%
      }{}%
    }{}{}%
  }{}%
}
