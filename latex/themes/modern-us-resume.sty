\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{themes/modern-us-resume}[2026-04-14 Modern US resume theme]
% Layout derived from themes/us-resume.sty. Modernizes visual style only:
% no small caps, quieter accent, gray secondary metadata, tighter typography.

\RequirePackage[\cv@papersize, margin=0.75in]{geometry}
\RequirePackage[en-US, useregional]{datetime2}

\newbool{BadgeToggled}
\newcommand{\InsertHeader}{}

\setlength{\parindent}{0pt}
\DTMsetstyle{en-US}

\pagestyle{fancy}
\fancypagestyle{letter}{\fancyhf{}}
\chead{\InsertHeader}
\rhead{\ifbool{BadgeToggled}{\InsertBadge}{}}
\lfoot{\FooterGrayColor{\today}}
\geometry{includehead, headsep=0.2in, footskip=0.25in}
\fancypagestyle{noheader}{\fancyhead{}}

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
%
% Colors
%
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

% Muted slate blue — professional and restrained vs the default bright blue.
\definecolor{ModernAccent}{HTML}{4A6FA5}
\colorlet{accentColor}{ModernAccent}

% Medium gray for all secondary metadata (dates, org, location).
\definecolor{ModernGray}{HTML}{666666}

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
%
% Header
%
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

% \MakeHeader{name}{subtitle}{contact-line}
%
% Name is bold at \LARGE — prominent but not academic-oversized.
% No \textsc anywhere; sans-serif weight carries the hierarchy.
\newcommand*{\MakeHeader}[3]{%
  \def\InsertHeader{%
    {\LARGE\bfseries #1}\\[1pt]%
    {\small #2}\\[1pt]%
    {\small #3}%
  }%
}

\newcommand*{\SetBadge}[2]{%
  \booltrue{BadgeToggled}%
  \def\InsertBadge{\includegraphics[scale=#1]{#2}}%
}

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
%
% Section headings
%
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

% \large (12 pt at 10 pt base) instead of \Large (14.4 pt): readable but
% quieter. Accent color + rule provides the visual landmark; the label
% does not need to shout.
\renewcommand*{\cv@render@sectionheading}[1]{%
  \vspace{4mm}%
  \noindent{\large\bfseries\color{accentColor}#1}%
  ~\textcolor{light_gray}{\hrulefill}\par%
}

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
%
% CV entry
%
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

% Title: bold at body size — weight alone distinguishes it from bullets.
% Dates, org, location: \small gray — secondary info reads quietly without
% accent color or small caps.
\renewcommand*{\cv@render@entry}[1]{%
  \begin{minipage}{\textwidth}
  \vspace{4mm}%
  \setlength\tabcolsep{0pt}%
  \setlength{\extrarowheight}{0pt}%
  \begin{tabularx}{\textwidth}{X r}
    \textbf{\cv@entry@linktitle} & {\small\color{ModernGray}\cv@entry@dates} \\
    {\small\color{ModernGray}\cv@entry@org} & {\small\color{ModernGray}\cv@entry@location}
  \end{tabularx}
  #1
  \end{minipage}%
}

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
%
% CV item
%
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

\renewcommand*{\cv@render@item}[2]{%
  \vspace{1.5mm}%
  \setlength\tabcolsep{0pt}%
  \setlength{\extrarowheight}{0pt}%
  \begin{tabularx}{\textwidth}{l l X}%
    \textbf{#1} & \hspace{0.3cm} & #2 \\
  \end{tabularx}%
}

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
%
% Cover letter
%
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

\fancypagestyle{letter}{\fancyhf{}}

\renewcommand{\cv@renderletter@begin}{%
  \thispagestyle{letter}%
  \newgeometry{margin=0.75in}%
  {\Large\bfseries \DisplayName}\\
  \@ifundefined{DisplayAddressOne}{}{\DisplayAddressOne\\}%
  \@ifundefined{DisplayAddressTwo}{}{\DisplayAddressTwo\\}%
  \@ifundefined{DisplayAddressThree}{}{\DisplayAddressThree\\}%
  \@ifundefined{DisplayPhone}{}{\DisplayPhone\\}%
  \@ifundefined{DisplayEmail}{}{\DisplayEmail\\}%
  \today\\[1\baselineskip]
  \cv@letter@toname\\
  \cv@letter@toaddress\\[1\baselineskip]
  \textbf{\cv@letter@subject}\\[0.5\baselineskip]
  \cv@letter@opening\\
}

\renewcommand{\cv@renderletter@end}{%
  \par
  \cv@letter@closing,\\
  \ifthenelse{\equal{\cv@letter@signature}{}}%
    {\\[3\baselineskip]}%
    {\includegraphics[height=3\baselineskip]{\cv@letter@signature}\\}%
  \DisplayName
  \restoregeometry
  \setcounter{page}{1}%
}

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
%
% Deprecated shims
%
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

\newcommand*{\cventrylegacy}[5]{%
  \def\cv@entry@dates{#1}%
  \def\cv@entry@title{#2}%
  \def\cv@entry@org{#3}%
  \def\cv@entry@location{#4}%
  \def\cv@entry@url{}%
  \cv@render@entry{#5}%
}

\newcommand*{\cvlistitem}[3]{%
  \vspace{1.5mm}%
  \setlength\tabcolsep{0pt}%
  \setlength{\extrarowheight}{0pt}%
  \begin{tabularx}{\textwidth}{l l X}%
    \ifthenelse{\equal{#3}{}}%
      {\textbf{#1}}%
      {\href{#3}{\textbf{#1}}}%
      & \hspace{0.3cm} & #2 \\
  \end{tabularx}\\%
}
